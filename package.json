{
  "name": "@testsmith/api-spector",
  "productName": "api Spector",
  "version": "0.1.5",
  "description": "Local-first API testing tool to inspect, test and mock APIs",
  "repository": {
    "type": "git",
    "url": "https://github.com/testsmith-io/api-spector"
  },
  "bugs": {
    "url": "https://github.com/testsmith-io/api-spector/issues"
  },
  "homepage": "https://github.com/testsmith-io/api-spector",
  "license": "GPL-3.0-only",
  "main": "out/main/index.js",
  "bin": {
    "api-spector": "bin/cli.js"
  },
  "files": [
    "out/",
    "bin/",
    "resources/splash.html",
    "build/icon.png"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "runner": "node out/main/runner.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "build:icons": "node scripts/build-icons.mjs",
    "prepare": "npm run build:icons && node scripts/patch-electron-name.mjs",
    "prepublishOnly": "npm run build && npm run build:icons"
  },
  "devDependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/tv4": "^1.2.33",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.27",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@faker-js/faker": "^10.4.0",
    "@uiw/react-codemirror": "^4.25.8",
    "@xmldom/xmldom": "^0.8.11",
    "ajv": "^8.18.0",
    "dayjs": "^1.11.20",
    "electron": "~31.7.0",
    "immer": "^11.1.4",
    "js-yaml": "^4.1.1",
    "jsonpath-plus": "^10.4.0",
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "simple-git": "^3.33.0",
    "tv4": "^1.3.0",
    "undici": "^7.24.5",
    "uuid": "^9.0.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.apispector.app",
    "productName": "api Spector",
    "icon": "build/icon.png",
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/splash.html",
        "to": "splash.html"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "releaseType": "draft"
    }
  }
}