{
  "name": "@testsmith/api-spector",
  "productName": "api Spector",
  "version": "0.0.3",
  "description": "Local-first API testing tool to inspect, test and mock APIs",
  "repository": {
    "type": "git",
    "url": "https://github.com/testsmith-io/api-spector"
  },
  "bugs": {
    "url": "https://github.com/testsmith-io/api-spector/issues"
  },
  "homepage": "https://github.com/testsmith-io/api-spector",
  "main": "out/main/index.js",
  "bin": {
    "api-spector": "bin/cli.js"
  },
  "files": [
    "out/",
    "bin/",
    "resources/splash.html",
    "build/icon.png"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "runner": "node out/main/runner.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "build:icons": "node scripts/build-icons.mjs",
    "prepare": "npm run build:icons && node scripts/patch-electron-name.mjs",
    "prepublishOnly": "npm run build && npm run build:icons"
  },
  "devDependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@eslint/js": "^9.39.4",
    "@types/js-yaml": "^4.0.9",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/tv4": "^1.2.33",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^5.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@faker-js/faker": "^10.3.0",
    "@uiw/react-codemirror": "^4.23.0",
    "ajv": "^8.17.1",
    "dayjs": "^1.11.20",
    "electron": "^31.0.0",
    "immer": "^10.1.1",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "node-soap": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tv4": "^1.3.0",
    "undici": "^6.19.2",
    "uuid": "^10.0.0",
    "ws": "^8.20.0",
    "zustand": "^4.5.4"
  },
  "build": {
    "appId": "com.apispector.app",
    "productName": "api Spector",
    "icon": "build/icon.png",
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/splash.html",
        "to": "splash.html"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "releaseType": "draft"
    }
  }
}